{
  "name": "code-agent-launcher",
  "version": "0.1.0",
  "description": "A lightweight profile launcher for coding-agent CLIs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cagent": "dist/index.js"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "build:standalone": "bun scripts/build-standalone.ts",
    "start": "node dist/index.js",
    "dev": "bun src/index.ts",
    "test": "bun test src/ validation/",
    "validate": "bun validation/runner.ts",
    "validate:check": "tsc --noEmit -p validation/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json && bun run validate:check",
    "lint": "biome lint src/ scripts/ validation/ && bun run typecheck",
    "lint:fix": "biome lint --write src/ scripts/",
    "format": "biome format --write src/ scripts/ validation/",
    "format:check": "biome format src/ scripts/ validation/",
    "check": "biome check src/ scripts/ validation/ && bun run typecheck"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^20.14.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "coding-agent",
    "cagent",
    "cli",
    "wrapper"
  ],
  "license": "MIT"
}
